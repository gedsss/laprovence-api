// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  gestor
  noivo
}

enum Setor {
  Mesa_posta
  Prataria
  Adornos
  Aromas
  Mobiliario
  Vasos
  Complementos
}

enum StatusCatalogo {
  Ativo
  Inativo
}

enum StatusLista {
  Ativa
  Arquivada
}

enum StatusPagamento {
  Pendente
  Aprovado
  Rejeitado
  Cancelado
}

model user {
  id                    String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome_noiva            String    @db.VarChar(50)
  nome_noivo            String    @db.VarChar(50)
  email                 String    @unique @db.VarChar(255)
  telefone              String    @unique @db.VarChar(16)
  data_casamento        DateTime  @db.Date
  password              String    @db.Text
  reset_password_token  String?   @unique
  reset_password_expire DateTime?
  foto_casal            String?   @db.Text
  role                  Role      @default(noivo)
  is_system             Boolean   @default(false)
  created_at            DateTime  @default(now()) @db.Timestamptz()
  updated_at            DateTime  @default(now()) @updatedAt @db.Timestamptz()
  listas                listas[]
}

model catalogo {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome             String             @db.Text
  marca            String?            @db.Text
  tamanho          String?            @db.Text
  descricao        String?            @db.Text
  preco            Decimal            @default(0) @db.Decimal(10, 2)
  setor            Setor
  estoque          Int                @default(0) @db.Integer
  quantidade       Int                @default(1) @db.Integer
  peso             Decimal            @default(0) @db.Decimal(6, 2)
  status           StatusCatalogo     @default(Ativo)
  version          Int                @default(1) @db.Integer
  created_at       DateTime           @default(now()) @db.Timestamptz()
  updated_at       DateTime           @default(now()) @updatedAt @db.Timestamptz()
  catalogo_images  catalogo_images[]
  lista_itens      lista_itens[]
  compras          compras[]
  premontada_itens premontada_itens[]

  @@index([setor])
  @@index([status])
  @@index([setor, status])
}

model catalogo_images {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  catalogo_id String   @db.Uuid
  catalogo    catalogo @relation(fields: [catalogo_id], references: [id])
  url         String   @db.Text
  posicao     Int      @default(0) @db.Integer
  created_at  DateTime @default(now()) @db.Timestamptz()

  @@index([catalogo_id])
}

model listas {
  id                   String        @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  codigo               String        @unique @db.Char(6)
  user_id              String        @db.Uuid
  user                 user          @relation(fields: [user_id], references: [id])
  nome_noivos          String        @db.Text
  telefone             String?       @db.Text
  data_casamento       DateTime?     @db.Date
  foto_casal           String?       @db.Text
  mensagem_boas_vindas String?       @db.Text
  status               StatusLista   @default(Ativa)
  created_at           DateTime      @default(now()) @db.Timestamptz()
  updated_at           DateTime      @default(now()) @updatedAt @db.Timestamptz()
  lista_itens          lista_itens[]
  compras              compras[]

  @@index([user_id])
}

model lista_itens {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listas_id   String   @db.Uuid
  listas      listas   @relation(fields: [listas_id], references: [id])
  catalogo_id String   @db.Uuid
  catalogo    catalogo @relation(fields: [catalogo_id], references: [id])
  added_at    DateTime @default(now()) @db.Timestamptz()

  @@index([listas_id])
  @@index([catalogo_id])
}

model compras {
  id                   String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  listas_id            String          @db.Uuid
  listas               listas          @relation(fields: [listas_id], references: [id])
  catalogo_id          String?         @db.Uuid
  catalogo             catalogo?       @relation(fields: [catalogo_id], references: [id])
  nome_convidado       String          @db.Text
  email                String?         @db.Text
  cpf                  String          @db.Char(11)
  telefone             String          @db.Text
  valor_pago           Decimal         @db.Decimal(10, 2)
  forma_pagamento      String          @db.Text
  status_pagamento     StatusPagamento @default(Pendente)
  pagbank_order_id     String?         @db.Text
  checkout_access_hash String?         @db.Char(64)
  is_new_gestor        Boolean         @default(true) @db.Boolean
  is_new_noivo         Boolean         @default(false) @db.Boolean
  data_compra          DateTime        @default(now()) @db.Timestamptz()
  created_at           DateTime        @default(now()) @db.Timestamptz()

  @@index([listas_id])
  @@index([cpf])
  @@index([status_pagamento])
}

model premontadas {
  id               String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  nome             String             @db.Text
  descricao        String?            @db.Text
  badge            String?            @db.Text
  popular          Boolean?           @default(false) @db.Boolean
  img              String?            @db.Text
  premontada_itens premontada_itens[]
}

model premontada_itens {
  premontada_id String      @db.Uuid
  catalogo_id   String      @db.Uuid
  premontadas   premontadas @relation(fields: [premontada_id], references: [id], onDelete: Cascade)
  catalogo      catalogo    @relation(fields: [catalogo_id], references: [id], onDelete: Cascade)

  @@id([premontada_id, catalogo_id])
}
