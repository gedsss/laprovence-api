DATABASE_URL="postgresql://user:password@localhost:5432/db_name"

JWT_PASS="your_jwt_secret_here"

REDIS_URL="redis://localhost:6379"

# PagBank — gere o token em: https://minha.conta.pagseguro.uol.com.br/aplicacoes-merchant
PAGBANK_TOKEN="seu_token_aqui"
# "sandbox" para testes, "production" para produção
PAGBANK_ENV="sandbox"
# URL pública que o PagBank vai chamar quando o status do pedido mudar
# Em desenvolvimento, use ngrok: npx ngrok http 3668
PAGBANK_WEBHOOK_URL="https://sua-url-publica.com/pagbank/webhook"
PAGBANK_WEBHOOK_SIGNATURE_REQUIRED="true"

# Opcional localmente. Em homologacao/producao, preencha para proteger o checkout publico.
RECAPTCHA_SECRET_KEY="sua_secret_key_recaptcha_v3"
RECAPTCHA_MIN_SCORE="0.5"

# Opcional: se preenchido, restringe CORS aos dominios listados por virgula.
CORS_ORIGINS="https://seu-front.com"
